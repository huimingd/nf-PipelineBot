wave {
    enabled = true
    strategy = ['conda']
}

conda {
    enabled = true
    channels = ['conda-forge', 'bioconda', 'defaults']
}

params {
    // PipelineBot repository settings
    pipelinebot_repo = "https://github.com/huimingd/PipelineBot.git"
    pipelinebot_revision = "main"
    
    // Pipeline configuration
    config_file = null  // Path to custom YAML config file
    output_dir = "results"
    log_level = "INFO"
    
    // SLURM execution settings (optional)
    use_slurm = false
    slurm_partition = null
    slurm_account = null
    slurm_time_limit = "04:00:00"
    slurm_mem_gb = null
    slurm_nodes = null
    slurm_ntasks_per_node = null
    slurm_work_dir = "/tmp/pipeline_slurm"
    slurm_python = "python"
    slurm_poll_interval = 10
    
    // Input data paths (customize these for your specific pipeline)
    reference_genome = null
    annotation_file = null
    fastq_files = []
    bam_files = []
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Capture Nextflow log files
timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_info/execution_timeline.html"
}
report {
    enabled = true
    file = "${params.output_dir}/pipeline_info/execution_report.html"
}
trace {
    enabled = true
    file = "${params.output_dir}/pipeline_info/execution_trace.txt"
}
dag {
    enabled = true
    file = "${params.output_dir}/pipeline_info/pipeline_dag.svg"
}
